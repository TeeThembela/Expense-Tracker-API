# ── Database ─────────────────────────────────────────────────────────────────
DB_HOST=
DB_PORT=
DB_NAME=
DB_USERNAME=
DB_PASSWORD=

# ── JWT ──────────────────────────────────────────────────────────────────────
# SECRET_KEY must be a Base64-encoded string of at least 32 bytes.
JWT_SECRET_KEY=
JWT_ACCESS_TOKEN_EXPIRATION=
JWT_REFRESH_TOKEN_EXPIRATION=
JWT_ISSUER=

# ── Springdoc ─────────────────────────────────────────────────────────────────
# Set both to false in production.
SPRINGDOC_API_DOCS_ENABLED=
SPRINGDOC_SWAGGER_UI_ENABLED=
